# Controls for volume and brightness
#	bindsym XF86AudioRaiseVolume 	exec pactl set-sink-volume @DEFAULT_SINK@ +10%
	bindsym XF86AudioRaiseVolume    exec $lbin/volumeUpFixed
	bindsym XF86AudioLowerVolume 	exec pactl set-sink-volume @DEFAULT_SINK@ -10%
	bindsym XF86AudioMute 			exec pactl set-sink-mute @DEFAULT_SINK@ toggle

#	bindsym	XF86MonBrightnessDown	exec brightnessctl s 4-%
	bindsym XF86MonBrightnessDown 	exec $lbin/brightnessDownFixed
	bindsym XF86MonBrightnessUp 	exec $lbin/brightnessUpFixed
#	bindsym XF86PowerOff

	bindsym $mod+Shift+o		exec firefox "http://server.qnss.it/aule.html"
	bindsym $mod+Shift+a		exec firefox "http://daisydata.freeddns.org:9328"

# Mute mic (no dedicated button)
   	bindsym $mod+Shift+m   	    exec pactl set-source-mute @DEFAULT_SOURCE@ toggle

# Take a screenshot of the whole screen
	bindsym Print 			exec grim ~/Pictures/screenshot/screenshot-$(date +%F_%H%M%S_%3N).png

# Image to clipboard
#	bindsym	--release Shift+Print	exec import
	bindsym --release Shift+Print	exec grim -g "$(slurp)" - | wl-copy

# Lock screen with swaylock
	bindsym XF86ScreenSaver exec swaylock\
		--clock\
		--timestr "%H:%M"\
		--indicator\
		--effect-blur 7x5\
		--ignore-empty-password\
		--screenshots
#		-i $wallpaper

# Read `man 5 sway-bar` for more information about this section.

# Status bar colors
set $st #ffffffa0
set $bg #46472bff
set $tx #ffffffa0

bar {
    position bottom

    # When the status_command prints a new line to stdout, swaybar updates.
    # The default just shows the current date and time.
    status_command while ~/.config/sway/status.sh; do sleep 0.4; done

	# Sway-bar gaps
	#	gaps 8

    colors {
        # text color
		statusline $st

		# background color
		background $bg


		# Workspace colors <border> <background> <text>

		# current workspace
		focused_workspace $tx $tx $bg

		urgent_workspace $tx $bg $tx
	    inactive_workspace $bg $bg $tx

    }
	font pango:DejaVu Sans Mono 10
}

